      ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"While", "[", 
        RowBox[{
         RowBox[{"x", "<", 
          RowBox[{"xMax", " ", "-", " ", 
           RowBox[{"10", "^", 
            RowBox[{"-", "12"}]}]}]}], ",", "\[IndentingNewLine]", 
