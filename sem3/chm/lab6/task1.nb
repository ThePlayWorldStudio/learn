          RowBox[{"yPred", "=", 
           RowBox[{"y", "+", 
            RowBox[{"h", " ", "k1"}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"y", "=", 
           RowBox[{"y", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"h", "/", "2"}], ")"}], 
             RowBox[{"(", 
              RowBox[{"k1", "+", 
               RowBox[{"f", "[", 
                RowBox[{
                 RowBox[{"x", "+", "h"}], ",", " ", "yPred"}], "]"}]}], 
              ")"}]}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"x", "=", 
           RowBox[{"x", "+", "h"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"pts", ",", " ", 
            RowBox[{"{", 
             RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}], ";"}]}], 
